{
  "name": "event-source",
  "version": "1.0.0",
  "description": "Simple event source server",
  "keywords": [],
  "homepage": "https://github.com/Balmath/event-source#readme",
  "bugs": {
    "url": "https://github.com/Balmath/event-source/issues"
  },
  "license": "MIT",
  "author": "Mathieu Balland",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Balmath/event-source.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "npm run fmt && npm run lint && npm run test",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
